<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chabungus LLC - Portfolio</title>

<meta property="og:title" content="Chabungus LLC - Roblox Games & Investments">
<meta property="og:description" content="We develop and invest in Roblox games, boosting retention and revenue.">
<meta property="og:url" content="https://chabungus.com">

<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">
<link rel="icon" href="/Chabungus C 128.png">
<link rel="stylesheet" href="styles.css">
</head>
<body>

<header>
  <img src="/Chabungus Logo.png" alt="Chabungus LLC" class="header-logo" />
  <nav>
    <a href="/">About</a>
    <a href="/portfolio">Portfolio</a>
    <a href="/invest">Invest</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<section id="portfolio">
  <h2>Game Portfolio</h2>
  <p>Performance transparency for acquisition inquiries.</p>

  <p class="portfolio-note">
    We are always open to sell % in games for the right price, so we display how much % in each game we still own, for your convenience.
  </p>

  <div class="grid-3" id="portfolio-grid"></div>
  
  <div class="warning">
    I can smell a scam from a mile away. Legitimate offers only.
  </div>
</section>

<footer>
  © 2026 Chabungus LLC — All Rights Reserved
</footer>

<script>
// === PORTFOLIO CONFIG ===
const games = [
  { id: "9011180012", ownership: 50, forSale: false, originalCreator: "Chabungus LLC" },
  { id: "9297684035", ownership: 20, forSale: null, originalCreator: "Chabungus LLC" },
  { id: "9406855770", ownership: 100, forSale: false, originalCreator: "Chabungus LLC" },
  { id: "4727281805", ownership: 50, forSale: false, originalCreator: "Chabungus LLC" }
];

const MIN_CCU_VISIBLE = 10;

async function buildPortfolio() {
  const container = document.getElementById("portfolio-grid");
  container.innerHTML = "";
  const ids = games.map(g => g.id);

  try {
    const gameRes = await fetch(
      `https://gamesrobloxcom-proxy.vercel.app/v1/games?universeIds=${ids.join(",")}`
    );
    const gameJson = await gameRes.json();
    const gameDataArray = gameJson.data;

    const thumbPayload = ids.map(id => ({
      requestId: `${id}::GameIcon:512x512:png:regular`,
      type: "GameIcon",
      targetId: Number(id),
      size: "512x512",
      format: "png",
      isCircular: false
    }));

    const thumbRes = await fetch(
      "https://thumbnailsrobloxcom.vercel.app/v1/batch",
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(thumbPayload)
      }
    );
    const thumbJson = await thumbRes.json();
    const thumbDataArray = thumbJson.data;

    const merged = games.map(gameObj => {
      const gameData = gameDataArray.find(g => g.id.toString() === gameObj.id);
      const thumbData = thumbDataArray.find(t => t.targetId.toString() === gameObj.id);
      if (!gameData) return null;
      return {
        ...gameObj,
        name: gameData.name,
        playing: gameData.playing,
        visits: gameData.visits,
        rootPlaceId: gameData.rootPlaceId,
        thumbnailUrl: thumbData?.imageUrl || ""
      };
    }).filter(Boolean);

    merged.sort((a, b) => b.playing - a.playing);

    merged.forEach(game => {
      const card = document.createElement("div");
      card.className = "card";
      card.style.cursor = "pointer";

      card.innerHTML = `
        <img src="${game.thumbnailUrl}" class="portfolio-thumb" />
        <h3>${game.name}</h3>
        <div class="live-metric">
          <div class="live-number">${game.playing.toLocaleString()}</div>
          <div class="live-label">Live Players</div>
        </div>
        <div class="secondary-metric">
          <span>${game.visits.toLocaleString()}</span> total visits
        </div>
        <div class="metric-divider"></div>
        <div class="meta">
          Ownership: ${game.ownership}%<br>
          Created by: ${game.originalCreator}
        </div>
        <div class="card-overlay">View on Roblox →</div>
      `;

      card.addEventListener("click", () => {
        const placeId = game.rootPlaceId;
        const url = `https://www.roblox.com/games/${placeId}`;
        window.open(url, "_blank");
      });

      container.appendChild(card);
    });
  } catch (err) {
    console.error(err);
    container.innerHTML =
      '<p style="color:red;">Failed to load portfolio data.</p>';
  }
}

buildPortfolio();
</script>

</body>
</html>
