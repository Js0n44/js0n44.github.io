<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Chabungus LLC - Home</title>

<meta property="og:title" content="Chabungus LLC - Roblox Games & Investments">
<meta property="og:description" content="We develop and invest in Roblox games, boosting retention and revenue.">
<meta property="og:url" content="https://chabungus.com">

<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">
<link rel="icon" href="/Chabungus C 128.png">
<link rel="stylesheet" href="styles.css">
<style>
/* Hero overrides for standalone page */
.hero {
  position: relative;
  padding: 140px 8% 80px;
  text-align: center;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.hero canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.hero h1 {
  font-size: 3.5rem;
  background: linear-gradient(90deg, var(--accent), var(--accent-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.2;
  margin-bottom: 20px;
  position: relative;
  z-index: 1;
  opacity: 0;
  transform: translateY(40px);
  animation: heroFadeSlide 1s ease forwards;
}

.hero p {
  color: var(--muted);
  max-width: 700px;
  margin: 0 auto 40px;
  font-size: 1.1rem;
  line-height: 1.7;
  position: relative;
  z-index: 1;
}

.hero .hero-buttons {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  justify-content: center;
  z-index: 1;
  position: relative;
}

.hero .hero-buttons a {
  display: inline-block;
  padding: 14px 28px;
  background: var(--accent);
  border-radius: 8px;
  font-weight: 600;
  color: #fff;
  text-decoration: none;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.hero .hero-buttons a:hover {
  transform: translateY(-3px);
  box-shadow: 0 0 20px rgba(255, 122, 24, 0.25);
}

@keyframes heroFadeSlide {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>
</head>
<body>

<header>
  <img src="/Chabungus Logo.png" alt="Chabungus LLC" class="header-logo" />
  <nav>
    <a href="/portfolio">Portfolio</a>
    <a href="/invest">Invest</a>
    <a href="/contact">Contact</a>
  </nav>
</header>

<section class="hero">
  <canvas id="particle-canvas"></canvas>
  <h1>Roblox Game <span>Creation & Early Investing</span></h1>
  <p>
    Chabungus LLC is a Roblox game creation entity focused on developing our own high-performing games
    while also investing in and acquiring other games.
  </p>
  <div class="hero-buttons">
    <a href="/portfolio">View Portfolio</a>
    <a href="/invest">Invest With Us</a>
    <a href="/contact">Get In Touch</a>
  </div>
</section>

<footer>
  © 2026 Chabungus LLC — All Rights Reserved
</footer>

<script>
// === PARTICLE BACKGROUND ===
const canvas = document.getElementById('particle-canvas');
const ctx = canvas.getContext('2d');
let particles = [];
let width = canvas.width = canvas.offsetWidth;
let height = canvas.height = canvas.offsetHeight;

class Particle {
  constructor() {
    this.x = Math.random() * width;
    this.y = Math.random() * height;
    this.radius = Math.random() * 2 + 1;
    this.vx = (Math.random() - 0.5) * 0.5;
    this.vy = (Math.random() - 0.5) * 0.5;
  }
  draw() {
    ctx.beginPath();
    ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
    ctx.fillStyle = 'rgba(255,122,24,0.6)';
    ctx.fill();
  }
  update() {
    this.x += this.vx;
    this.y += this.vy;
    if (this.x < 0 || this.x > width) this.vx *= -1;
    if (this.y < 0 || this.y > height) this.vy *= -1;
    this.draw();
  }
}

function initParticles(num = 120) {
  particles = [];
  for (let i = 0; i < num; i++) {
    particles.push(new Particle());
  }
}

function animate() {
  ctx.clearRect(0, 0, width, height);
  particles.forEach(p => p.update());
  requestAnimationFrame(animate);
}

window.addEventListener('resize', () => {
  width = canvas.width = canvas.offsetWidth;
  height = canvas.height = canvas.offsetHeight;
  initParticles();
});

initParticles();
animate();
</script>

</body>
</html>
